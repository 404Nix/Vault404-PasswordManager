{
  "name": "vault404-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:frontend": "cd frontend-Vault404 && npm run dev",
    "dev:backend": "cd backend-Vault404 && npm run dev",
    "build:frontend": "cd frontend-Vault404 && npm run build",
    "build:backend": "cd backend-Vault404 && npm run build",
    "build:all": "npm run build:frontend && npm run build:backend",
    "start:backend": "cd backend-Vault404 && npm start"
  }
}
